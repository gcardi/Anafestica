// Render with:
//   dot -Tsvg docs/assets/images/class_diagram.dot -o docs/assets/images/class_diagram.svg
digraph AnafesticaClassDiagram {
  graph [
    label="Anafestica Library - Class Diagram",
    labelloc=t,
    fontsize=28,
    fontname="Arial",
    rankdir=TB,
    splines=ortho,
    overlap=false,
    concentrate=false,
    compound=true,
    nodesep=0.7,
    ranksep=0.95,
    pad=0.35,
    bgcolor="white"
  ];

  node [
    shape=plain,
    fontname="Arial"
  ];

  edge [
    fontname="Arial",
    fontsize=11,
    color="#373435",
    arrowsize=0.8
  ];

  TConfig [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#373435">
        <TR><TD><I><B>Anafestica::TConfig</B></I></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;abstract&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">- readOnly_: bool</TD></TR>
        <TR><TD ALIGN="LEFT">- flushAllItems_: bool</TD></TR>
        <TR><TD ALIGN="LEFT">- root_: unique_ptr&lt;TConfigNode&gt;</TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ GetRootNode(): TConfigNode&amp;</TD></TR>
        <TR><TD ALIGN="LEFT">+ Flush(): void</TD></TR>
        <TR><TD ALIGN="LEFT"># DoCreateValueList(path)</TD></TR>
        <TR><TD ALIGN="LEFT"># DoCreateNodeList(path)</TD></TR>
        <TR><TD ALIGN="LEFT"># DoSaveValueList(path, values)</TD></TR>
        <TR><TD ALIGN="LEFT"># DoDeleteNode(path)</TD></TR>
        <TR><TD ALIGN="LEFT"># DoFlush()</TD></TR>
      </TABLE>
    >
  ];

  TConfigNode [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#373435">
        <TR><TD><B>TConfigNode</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">- valueItems_: ValueContType</TD></TR>
        <TR><TD ALIGN="LEFT">- nodeItems_: NodeContType</TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ GetSubNode(id)</TD></TR>
        <TR><TD ALIGN="LEFT">+ GetItem&lt;T&gt;(id)</TD></TR>
        <TR><TD ALIGN="LEFT">+ PutItem&lt;T&gt;(id, value)</TD></TR>
        <TR><TD ALIGN="LEFT">+ Enumerate*()</TD></TR>
        <TR><TD ALIGN="LEFT">+ Read(reader, path)</TD></TR>
        <TR><TD ALIGN="LEFT">+ Write(writer, path)</TD></TR>
      </TABLE>
    >
  ];

  CfgConts [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>CfgConts.h</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">ValueContType</TD></TR>
        <TR><TD ALIGN="LEFT">NodeContType</TD></TR>
        <TR><TD ALIGN="LEFT">Operation</TD></TR>
      </TABLE>
    >
  ];

  CfgNodeValueType [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>CfgNodeValueType</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">variant / boost::variant</TD></TR>
        <TR><TD ALIGN="LEFT">TypeTag</TD></TR>
        <TR><TD ALIGN="LEFT">numeric, bool, String</TD></TR>
        <TR><TD ALIGN="LEFT">TDateTime, Currency</TD></TR>
        <TR><TD ALIGN="LEFT">bytes, string vectors</TD></TR>
      </TABLE>
    >
  ];

  PlainBackends [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#547aa5">
        <TR><TD><B>TConfig descendants</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;concrete backends&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">Registry::TConfig - Windows registry</TD></TR>
        <TR><TD ALIGN="LEFT">JSON::TConfig - .json, optional explicit tags</TD></TR>
        <TR><TD ALIGN="LEFT">BSON::TConfig - .bson, binary JSON stream</TD></TR>
        <TR><TD ALIGN="LEFT">YAML::TConfig - .yaml, fkYAML, flush-all</TD></TR>
        <TR><TD ALIGN="LEFT">XML::TConfig - .xml, XML document</TD></TR>
        <TR><TD ALIGN="LEFT">INIFile::TConfig - .ini, section/key layout</TD></TR>
      </TABLE>
    >
  ];

  BackendAPI [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>Common backend API</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ TConfig(file, flags...)</TD></TR>
        <TR><TD ALIGN="LEFT">+ Migrate(load, save)</TD></TR>
        <TR><TD ALIGN="LEFT">+ ~TConfig(): Flush()</TD></TR>
      </TABLE>
    >
  ];

  RAIIHelpers [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>Backend RAII helpers</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">RegObjRAII, BSONObjRAII</TD></TR>
        <TR><TD ALIGN="LEFT">YAMLObjRAII, IniFileRAII</TD></TR>
        <TR><TD ALIGN="LEFT">COM/XML document lifetime</TD></TR>
      </TABLE>
    >
  ];

  SingletonFns [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#547aa5">
        <TR><TD><B>GetConfigSingleton()</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;namespace helpers&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">Registry::GetConfigSingleton()</TD></TR>
        <TR><TD ALIGN="LEFT">JSON / BSON / YAML / XML / INIFile</TD></TR>
        <TR><TD ALIGN="LEFT">derive path from version info</TD></TR>
        <TR><TD ALIGN="LEFT">migrate previous-version file</TD></TR>
        <TR><TD ALIGN="LEFT">return static backend instance</TD></TR>
      </TABLE>
    >
  ];

  SingletonClasses [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#373435">
        <TR><TD><B>TConfig*Singleton</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;facade&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ static GetConfig(): TConfig&amp;</TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">TConfigRegistrySingleton</TD></TR>
        <TR><TD ALIGN="LEFT">TConfigJSON / BSON / YAML / XML</TD></TR>
        <TR><TD ALIGN="LEFT">TConfigINIFileSingleton</TD></TR>
      </TABLE>
    >
  ];

  CryptBackends [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#547aa5">
        <TR><TD><B>*Crypt::TConfig</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;encrypted wrappers&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">JSONCrypt::TConfig : JSON::TConfig</TD></TR>
        <TR><TD ALIGN="LEFT">BSONCrypt::TConfig : BSON::TConfig</TD></TR>
        <TR><TD ALIGN="LEFT">YAMLCrypt::TConfig : YAML::TConfig</TD></TR>
        <TR><TD ALIGN="LEFT">XMLCrypt::TConfig : XML::TConfig</TD></TR>
        <TR><TD ALIGN="LEFT">INIFileCrypt::TConfig : INIFile::TConfig</TD></TR>
      </TABLE>
    >
  ];

  CryptSingletons [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#373435">
        <TR><TD><B>TConfig*CryptSingleton</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;facade&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ static GetConfig(): TConfig&amp;</TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">JSONC, BSONC, YAMLC</TD></TR>
        <TR><TD ALIGN="LEFT">XMLC, INIC extensions</TD></TR>
        <TR><TD ALIGN="LEFT">Crypt::TOptions::Default()</TD></TR>
      </TABLE>
    >
  ];

  Migration [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>Migration.h / GetMigrationSource()</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">destination wins; old version source is loaded then saved</TD></TR>
      </TABLE>
    >
  ];

  PersistVCL [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#373435">
        <TR><TD><B>TPersistFormVCL&lt;CfgSingleton&gt;</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;template&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">: Vcl::Forms::TForm</TD></TR>
        <TR><TD ALIGN="LEFT">- configNode_: TConfigNode&amp;</TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ GetConfigRootNode()</TD></TR>
        <TR><TD ALIGN="LEFT">+ Restore/Save position, size, state</TD></TR>
      </TABLE>
    >
  ];

  PersistFMX [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#373435">
        <TR><TD><B>TPersistFormWinFMX&lt;CfgSingleton&gt;</B></TD></TR>
        <TR><TD><FONT POINT-SIZE="10">&lt;&lt;template&gt;&gt;</FONT></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">: Fmx::Forms::TForm</TD></TR>
        <TR><TD ALIGN="LEFT">- configNode_: TConfigNode&amp;</TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">+ GetConfigRootNode()</TD></TR>
        <TR><TD ALIGN="LEFT">+ Restore/Save window placement</TD></TR>
      </TABLE>
    >
  ];

  FileVersionInfo [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>TFileVersionInfo</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">CompanyName()</TD></TR>
        <TR><TD ALIGN="LEFT">ProductName()</TD></TR>
        <TR><TD ALIGN="LEFT">ProductVersion()</TD></TR>
        <TR><TD ALIGN="LEFT">OriginalFileName()</TD></TR>
      </TABLE>
    >
  ];

  Version [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>TVersion</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">Major, Minor</TD></TR>
        <TR><TD ALIGN="LEFT">Release, Build</TD></TR>
        <TR><TD ALIGN="LEFT">Compare()</TD></TR>
      </TABLE>
    >
  ];

  Crypt [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#777777">
        <TR><TD><B>Crypt namespace</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT">TOptions { Enabled, Password, Salt, Iterations }</TD></TR>
        <TR><TD ALIGN="LEFT">AlgHandle, KeyHandle</TD></TR>
        <TR><TD ALIGN="LEFT">LoadBytes / SaveBytes</TD></TR>
        <TR><TD ALIGN="LEFT">LoadText / SaveText</TD></TR>
      </TABLE>
    >
  ];

  Patterns [
    label=<
      <TABLE BORDER="1" CELLBORDER="0" CELLSPACING="0" CELLPADDING="6" COLOR="#6a1b9a" BGCOLOR="#fbf5ff">
        <TR><TD><B>Design patterns</B></TD></TR>
        <HR/>
        <TR><TD ALIGN="LEFT"><B>Template Method</B>: TConfig hooks implemented by backends</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Composite</B>: TConfigNode tree owns child nodes</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Facade</B>: TConfig*Singleton hides setup details</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Singleton</B>: function-local static backend instance</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Decorator / Wrapper</B>: *Crypt::TConfig wraps file backends</TD></TR>
        <TR><TD ALIGN="LEFT"><B>RAII</B>: backend helper objects own resources</TD></TR>
        <TR><TD ALIGN="LEFT"><B>Policy / Template</B>: PersistForm takes CfgSingleton policy</TD></TR>
      </TABLE>
    >
  ];

  subgraph cluster_core {
    label="Core configuration model";
    color="#c8c8c8";
    style="rounded,dashed";
    TConfigNode;
    TConfig;
    CfgConts;
    CfgNodeValueType;
  }

  subgraph cluster_backends {
    label="Storage backends";
    color="#c8c8c8";
    style="rounded,dashed";
    PlainBackends;
    BackendAPI;
    RAIIHelpers;
  }

  subgraph cluster_singletons {
    label="Singleton facades and encrypted wrappers";
    color="#c8c8c8";
    style="rounded,dashed";
    SingletonFns;
    SingletonClasses;
    CryptBackends;
    CryptSingletons;
    Migration;
  }

  subgraph cluster_forms {
    label="Application integration";
    color="#c8c8c8";
    style="rounded,dashed";
    PersistVCL;
    PersistFMX;
  }

  subgraph cluster_utilities {
    label="Utilities";
    color="#c8c8c8";
    style="rounded,dashed";
    FileVersionInfo;
    Version;
    Crypt;
  }

  subgraph cluster_patterns {
    label="Patterns";
    color="#c8c8c8";
    style="rounded,dashed";
    Patterns;
  }

  TConfigNode -> TConfig -> CfgConts -> CfgNodeValueType [
    style=invis,
    weight=10
  ];

  PlainBackends -> BackendAPI -> RAIIHelpers [
    style=invis,
    weight=10
  ];

  SingletonFns -> SingletonClasses -> CryptBackends -> CryptSingletons [
    style=invis,
    weight=10
  ];

  PersistVCL -> PersistFMX [
    style=invis,
    weight=10
  ];

  FileVersionInfo -> Version -> Crypt [
    style=invis,
    weight=10
  ];

  PlainBackends -> TConfig [
    arrowhead=empty,
    label="inherits",
    constraint=false
  ];

  CryptBackends -> PlainBackends [
    arrowhead=empty,
    label="inherits / wraps"
  ];

  TConfig -> TConfigNode [
    arrowtail=diamond,
    arrowhead=none,
    dir=both,
    label="root"
  ];

  TConfigNode -> TConfigNode [
    arrowtail=diamond,
    arrowhead=none,
    dir=both,
    label="children 0..*"
  ];

  TConfigNode -> CfgConts [
    arrowhead=open,
    label="uses"
  ];

  TConfigNode -> CfgNodeValueType [
    arrowhead=open,
    label="stores"
  ];

  TConfig -> BackendAPI [
    style=dashed,
    arrowhead=normal,
    label="template hooks"
  ];

  BackendAPI -> RAIIHelpers [
    style=dashed,
    arrowhead=normal,
    label="resource lifetime"
  ];

  SingletonClasses -> SingletonFns [
    arrowhead=open,
    label="facade"
  ];

  SingletonFns -> PlainBackends [
    style=dashed,
    arrowhead=normal,
    label="constructs"
  ];

  CryptSingletons -> CryptBackends [
    style=dashed,
    arrowhead=normal,
    label="constructs"
  ];

  SingletonFns -> Migration [
    style=dashed,
    arrowhead=normal,
    label="uses"
  ];

  CryptSingletons -> Migration [
    style=dashed,
    arrowhead=normal,
    label="uses"
  ];

  SingletonFns -> FileVersionInfo [
    style=dashed,
    arrowhead=normal,
    label="derives path"
  ];

  FileVersionInfo -> Version [
    arrowhead=open,
    label="version fields"
  ];

  CryptBackends -> Crypt [
    style=dashed,
    arrowhead=normal,
    label="options / load-save"
  ];

  CryptSingletons -> Crypt [
    style=dashed,
    arrowhead=normal,
    label="default options"
  ];

  PersistVCL -> SingletonClasses [
    arrowhead=open,
    label="CfgSingleton policy"
  ];

  PersistFMX -> SingletonClasses [
    arrowhead=open,
    label="CfgSingleton policy"
  ];

  PersistVCL -> TConfigNode [
    arrowtail=odiamond,
    arrowhead=none,
    dir=both,
    label="configNode_"
  ];

  PersistFMX -> TConfigNode [
    arrowtail=odiamond,
    arrowhead=none,
    dir=both,
    label="configNode_"
  ];

  Patterns -> TConfig [
    style=dotted,
    color="#6a1b9a",
    fontcolor="#6a1b9a",
    arrowhead=none,
    label="pattern summary"
  ];
}
